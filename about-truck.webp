@import url("https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@400;500;600;700;800&display=swap");
:root{--black:#111;--charcoal:#1b1b1b;--navy:#1e2f45;--navy2:#142235;--red:#8b1e2d;--red2:#b32025;--gold:#c8a646;--gold2:#e1c978;--cream:#f6f2e8;--white:#fff;--muted:#d0d3d6;--border:rgba(200,166,70,.28);--shadow:0 18px 50px rgba(0,0,0,.28);--radius:18px;--max:1180px}
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:var(--black);color:var(--cream);font-family:Montserrat,Arial,sans-serif;line-height:1.65;padding-bottom:0}img{display:block;max-width:100%}a{color:inherit}.container{width:min(calc(100% - 32px),var(--max));margin:auto}.skip-link{position:fixed;top:-100px;left:16px;z-index:9999;background:var(--gold);color:#111;padding:10px 15px;font-weight:800}.skip-link:focus{top:16px}
.topbar{background:var(--red);font-size:.84rem}.topbar-inner{min-height:38px;display:flex;justify-content:space-between;align-items:center;gap:18px}.topbar a{text-decoration:none}.site-header{position:sticky;top:0;z-index:1000;background:rgba(17,17,17,.95);border-bottom:1px solid var(--border);backdrop-filter:blur(12px)}.site-header.is-scrolled{box-shadow:0 12px 30px rgba(0,0,0,.3)}.nav-wrap{min-height:86px;display:flex;align-items:center;justify-content:space-between;gap:24px}.brand{display:flex;align-items:center;gap:12px;text-decoration:none}.brand img{width:68px;height:68px;object-fit:contain}.brand-copy{display:grid}.brand-title{font-family:"Bebas Neue",Impact,sans-serif;font-size:1.75rem;line-height:1;letter-spacing:.045em}.brand-title strong{color:var(--gold)}.brand-sub{margin-top:4px;color:var(--muted);font-size:.72rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase}.nav{display:flex;align-items:center;gap:20px}.nav a{font-size:.86rem;font-weight:700;text-decoration:none}.nav a:hover,.nav a.active{color:var(--gold2)}.nav-cta{padding:11px 16px;border-radius:999px;background:var(--red2)}.menu-toggle{display:none;border:1px solid var(--border);border-radius:10px;background:transparent;color:white;padding:10px 14px;font:inherit;font-weight:700}
.hero{min-height:720px;display:grid;align-items:center;background:linear-gradient(90deg,rgba(8,12,18,.96),rgba(8,12,18,.78) 55%,rgba(8,12,18,.46)),url("../images/about-truck.webp") center/cover no-repeat}.hero-grid{display:grid;grid-template-columns:1.5fr .75fr;gap:70px;align-items:center;padding:92px 0 120px}.eyebrow{margin:0 0 10px;color:var(--gold2);font-weight:800;letter-spacing:.18em;text-transform:uppercase}.hero h1,.section-heading h2,.final-cta h2,.footer h2{margin:0;font-family:"Bebas Neue",Impact,sans-serif;line-height:.98;letter-spacing:.025em}.hero h1{font-size:clamp(4.1rem,9vw,7.8rem)}.hero h1 span{display:block;color:var(--gold)}.hero-summary{max-width:720px;margin:28px 0 24px;color:#e3e3e3;font-size:1.08rem}.mission-statement{display:flex;flex-wrap:wrap;gap:8px 18px;margin:24px 0;font-weight:800;text-transform:uppercase}.mission-statement strong{color:var(--gold2)}.button-row{display:flex;flex-wrap:wrap;gap:14px;margin-top:30px}.button-row.center{justify-content:center}.button{display:inline-flex;min-height:52px;align-items:center;justify-content:center;padding:13px 22px;border:2px solid var(--gold);border-radius:999px;font-weight:800;text-decoration:none;transition:.16s}.button:hover{transform:translateY(-2px)}.button-primary{border-color:var(--red2);background:var(--red2)}.button-secondary{background:rgba(17,17,17,.6)}.customer-promise{margin-top:28px;color:var(--gold2);font-weight:800}.hero-badge,.logo-panel,.service-area-card{padding:26px;border:1px solid var(--border);border-radius:26px;background:rgba(17,17,17,.74);box-shadow:var(--shadow);text-align:center}.hero-badge img{width:min(100%,390px);margin:auto}.hero-badge p{margin:16px 0 0;color:var(--gold2);font-weight:800;letter-spacing:.12em;text-transform:uppercase}
.trust-strip{border-block:1px solid var(--border);background:var(--navy2)}.trust-grid{display:grid;grid-template-columns:repeat(4,1fr)}.trust-grid div{padding:24px 22px;border-right:1px solid rgba(255,255,255,.09);text-align:center}.trust-grid div:last-child{border-right:0}.trust-grid strong,.trust-grid span{display:block}.trust-grid strong{color:var(--gold2)}.trust-grid span{margin-top:4px;color:var(--muted);font-size:.82rem}
.section{padding:96px 0}.section-heading{max-width:780px;margin:0 auto 44px;text-align:center}.section-heading.align-left{margin-left:0;text-align:left}.section-heading h2,.final-cta h2{font-size:clamp(2.9rem,6vw,5rem)}.section-heading>p:last-child{color:var(--muted)}.service-grid,.project-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}.card,.project-grid article{padding:30px;border:1px solid var(--border);border-radius:var(--radius);background:linear-gradient(145deg,rgba(30,47,69,.68),rgba(17,17,17,.92));box-shadow:0 12px 30px rgba(0,0,0,.18)}.icon{display:block;margin-bottom:18px;font-size:2.2rem}.card h3,.promise-grid h3,.project-grid h3{margin:0 0 8px}.card p,.project-grid p{margin:0;color:var(--muted)}.section-action{margin-top:34px;text-align:center}.text-link{color:var(--gold2);font-weight:800;text-decoration:none}
.standard-section,.gallery-section{background:var(--navy2)}.standard-grid,.founder-grid,.two-column{display:grid;grid-template-columns:.8fr 1.2fr;gap:62px;align-items:center}.logo-panel img{width:min(100%,440px);margin:auto}.promise-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:18px}.promise-grid article{display:flex;gap:14px;padding:20px;border:1px solid rgba(255,255,255,.09);border-radius:14px;background:rgba(17,17,17,.48)}.promise-grid article>span{color:var(--gold2);font-size:1.35rem;font-weight:900}.promise-grid p{margin:0;color:var(--muted);font-size:.9rem}.comparison-section{background:var(--charcoal)}.table-scroll{overflow-x:auto;border:1px solid var(--border);border-radius:var(--radius)}.comparison-table{width:100%;min-width:680px;border-collapse:collapse;background:#151515}.comparison-table th,.comparison-table td{padding:17px 20px;border-bottom:1px solid rgba(255,255,255,.08);text-align:left}.comparison-table thead th{background:var(--navy);color:var(--gold2)}.comparison-table tbody td:nth-child(2){color:var(--gold2);font-weight:800}.founder-photo{overflow:hidden;border:1px solid var(--border);border-radius:28px;box-shadow:var(--shadow)}.founder-photo img{width:100%;min-height:430px;object-fit:cover}.founder-grid p{color:var(--muted)}.project-grid article{min-height:240px;display:flex;flex-direction:column;justify-content:end;background:linear-gradient(180deg,rgba(17,17,17,.25),rgba(17,17,17,.98)),url("../images/about-truck.webp") center/cover no-repeat}.project-grid span{color:var(--gold2);font-size:.8rem;font-weight:800;text-transform:uppercase}.reviews-section{background:var(--cream);color:#111}.reviews-section .eyebrow{color:var(--red)}.review-card{padding:32px;border-radius:24px;background:white;box-shadow:0 16px 40px rgba(0,0,0,.12);text-align:center}.review-card strong{color:var(--gold);font-size:1.8rem}.service-area-card img{width:220px;margin:auto}.service-area-card a{color:var(--gold2);font-weight:800}.location-list{display:grid;grid-template-columns:repeat(2,1fr);gap:8px 22px;padding:0;list-style:none}.location-list li:before{content:"★";margin-right:8px;color:var(--gold)}
.final-cta{padding:94px 0;background:linear-gradient(rgba(17,17,17,.83),rgba(17,17,17,.94)),url("../images/about-truck.webp") center/cover no-repeat;text-align:center}.final-cta p:not(.eyebrow){max-width:680px;margin-inline:auto;color:var(--muted)}.footer{padding-top:70px;background:#090909;border-top:1px solid var(--border)}.footer-grid{display:grid;grid-template-columns:1.6fr .7fr .9fr;gap:48px;padding-bottom:48px}.footer-brand{display:grid;grid-template-columns:110px 1fr;gap:20px}.footer-brand img{width:110px}.footer h2{font-size:2.1rem}.footer h3{color:var(--gold2)}.footer a,.footer p{display:block;margin:0 0 9px;color:var(--muted);text-decoration:none}.footer-bottom{display:flex;justify-content:space-between;gap:20px;padding:20px 0;border-top:1px solid rgba(255,255,255,.08);color:#aeb2b6;font-size:.82rem}.mobile-actions{display:none}
@media(max-width:960px){.menu-toggle{display:inline-flex}.nav{position:absolute;left:16px;right:16px;top:100%;display:none;padding:18px;border:1px solid var(--border);border-radius:0 0 16px 16px;background:#101010;box-shadow:var(--shadow)}.nav.is-open{display:grid}.nav a{padding:11px 8px}.hero-grid,.standard-grid,.founder-grid,.two-column{grid-template-columns:1fr}.hero{min-height:auto}.hero-grid{gap:42px;padding:78px 0 100px}.hero-badge{max-width:500px}.trust-grid{grid-template-columns:repeat(2,1fr)}.service-grid,.project-grid{grid-template-columns:repeat(2,1fr)}.footer-grid{grid-template-columns:1fr 1fr}.footer-brand{grid-column:1/-1}}
@media(max-width:640px){body{padding-bottom:66px}.container{width:min(calc(100% - 24px),var(--max))}.topbar-inner{min-height:52px;flex-direction:column;justify-content:center;gap:2px;padding:6px 0;text-align:center}.brand img{width:54px;height:54px}.brand-title{font-size:1.35rem}.brand-sub{font-size:.58rem}.nav-wrap{min-height:72px}.hero{background-position:62% center}.hero-grid{padding:62px 0 90px}.hero h1{font-size:clamp(3.35rem,18vw,5.1rem)}.button-row{display:grid}.button{width:100%}.trust-grid,.service-grid,.project-grid,.promise-grid,.footer-grid{grid-template-columns:1fr}.trust-grid div{border-right:0;border-bottom:1px solid rgba(255,255,255,.09)}.section{padding:72px 0}.section-heading h2,.final-cta h2{font-size:3.15rem}.location-list{grid-template-columns:1fr}.footer-brand{grid-template-columns:84px 1fr}.footer-brand img{width:84px}.footer-bottom{flex-direction:column;text-align:center}.mobile-actions{position:fixed;inset:auto 0 0;z-index:1200;display:grid;grid-template-columns:1fr 1fr;background:#0b0b0b;box-shadow:0 -8px 24px rgba(0,0,0,.36)}.mobile-actions a{padding:16px 10px;font-weight:900;text-align:center;text-decoration:none}.mobile-actions a:first-child{background:var(--red2)}.mobile-actions a:last-child{background:var(--navy)}}
